 </head>
 <body class="bg-offwhite">
  <div id="app" class="app-root flex flex-col items-center"><!-- Screen: Home -->
   <div id="screen-home" class="screen active flex-col items-center justify-center w-full min-h-full px-6 py-12 text-center" style="background:linear-gradient(160deg,#faf8f5 0%,#f3e8ff 50%,#e9d5ff 100%)">
    <div class="fade-in max-w-md mx-auto"><!-- Bag SVG illustration -->
     <div class="glow mx-auto mb-8 w-48 h-48 rounded-3xl flex items-center justify-center" style="background:linear-gradient(135deg,#c084fc,#7e22ce)">
      <svg viewbox="0 0 120 120" width="120" height="120" fill="none"><path d="M35 45 C35 30, 45 22, 60 22 C75 22, 85 30, 85 45" stroke="#faf8f5" stroke-width="3" stroke-linecap="round" fill="none" /> <rect x="25" y="45" width="70" height="52" rx="12" fill="#faf8f5" fill-opacity=".15" stroke="#faf8f5" stroke-width="2.5" /> <circle cx="60" cy="65" r="4" fill="#fde68a" opacity=".9" /><line x1="60" y1="69" x2="60" y2="78" stroke="#fde68a" stroke-width="1.5" opacity=".6" /> <rect x="80" y="58" width="6" height="10" rx="2" fill="#faf8f5" opacity=".5" /> <path d="M38 80 h44" stroke="#faf8f5" stroke-width="1" opacity=".3" stroke-dasharray="3 3" />
      </svg>
     </div>
     <h1 id="home-title" class="font-display text-4xl font-bold text-lilac-700 mb-3">FlexBag 360</h1>
     <p id="home-slogan" class="text-lilac-500 text-lg font-light mb-10">Tecnologia, estilo e praticidade em um só lugar</p><button onclick="goTo('about')" class="bg-lilac-600 hover:bg-lilac-700 text-white px-10 py-4 rounded-2xl text-lg font-medium transition-all shadow-lg shadow-lilac-200 hover:shadow-xl hover:shadow-lilac-300 active:scale-95">Começar</button>
