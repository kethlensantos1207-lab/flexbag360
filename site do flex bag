  <script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        lilac: { 50:'#faf5ff', 100:'#f3e8ff', 200:'#e9d5ff', 300:'#d8b4fe', 400:'#c084fc', 500:'#a855f7', 600:'#9333ea', 700:'#7e22ce' },
