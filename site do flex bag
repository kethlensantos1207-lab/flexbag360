  <style>
html, body { height:100%; margin:0; font-family:'Outfit',sans-serif; }
.font-display { font-family:'Playfair Display',serif; }
.app-root { height:100%; width:100%; overflow:auto; }
.fade-in { animation: fadeIn .5s ease forwards; opacity:0; }
.fade-in-delay-1 { animation-delay:.1s }
.fade-in-delay-2 { animation-delay:.2s }
.fade-in-delay-3 { animation-delay:.3s }
.fade-in-delay-4 { animation-delay:.4s }
.fade-in-delay-5 { animation-delay:.5s }
@keyframes fadeIn { to { opacity:1; transform:translateY(0) } from { opacity:0; transform:translateY(12px) } }
@keyframes pulse-glow { 0%,100%{ box-shadow:0 0 20px rgba(168,85,247,.2) } 50%{ box-shadow:0 0 35px rgba(168,85,247,.4) } }
.glow { animation: pulse-glow 3s ease-in-out infinite; }
.star-btn { cursor:pointer; transition:transform .15s,color .15s; }
.star-btn:hover { transform:scale(1.2); }
input[type=radio] { accent-color:#9333ea; }
.screen { display:none; }
.screen.active { display:flex; }
::-webkit-scrollbar { width:4px } ::-webkit-scrollbar-thumb { background:#d8b4fe; border-radius:4px }
</style>
