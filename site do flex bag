      </div>
     </div><button onclick="goTo('survey')" class="mt-8 w-full bg-lilac-600 hover:bg-lilac-700 text-white py-4 rounded-2xl font-medium transition-all shadow-lg shadow-lilac-200 active:scale-95">Avaliar Produto <i data-lucide="arrow-right" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-left:4px"></i></button>
    </div>
   </div><!-- Screen: Survey -->
   <div id="screen-survey" class="screen flex-col w-full min-h-full px-5 py-8 bg-offwhite">
    <div class="max-w-lg mx-auto w-full"><button onclick="goTo('about')" class="text-lilac-500 mb-4 flex items-center gap-1 text-sm"><i data-lucide="arrow-left" style="width:16px;height:16px"></i> Voltar</button> <!-- Progress -->
     <div class="mb-6">
      <div class="flex justify-between text-xs text-lilac-400 mb-1">
       <span>Progresso</span><span id="progress-text">0/10</span>
      </div>
      <div class="h-2 bg-lilac-100 rounded-full overflow-hidden">
       <div id="progress-bar" class="h-full bg-gradient-to-r from-lilac-400 to-lilac-600 rounded-full transition-all duration-500" style="width:0%"></div>
      </div>
     </div>
     <h2 class="font-display text-2xl font-bold text-lilac-700 mb-6">Pesquisa de Satisfação</h2>
     <form id="survey-form" class="space-y-6" onsubmit="return false;"><!-- Q1: Stars -->
      <div class="bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm">
       <p class="text-sm font-medium text-lilac-700 mb-3">1. Como você avalia o design da FlexBag 360?</p>
       <div class="flex gap-2" id="stars-design"></div>
      </div><!-- Q2-Q9: Radio -->
      <div id="radio-questions"></div><!-- Q10: Stars -->
      <div class="bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm">
       <p class="text-sm font-medium text-lilac-700 mb-3">10. Qual sua avaliação geral do produto?</p>
       <div class="flex gap-2" id="stars-overall"></div>
      </div><!-- Additional comment -->
      <div class="bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm"><label class="text-sm font-medium text-lilac-700 mb-2 block">Comentário adicional (opcional)</label> <textarea id="additional-comment" rows="3" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300 resize-none" placeholder="Compartilhe sua opinião..."></textarea>
      </div><!-- Feedback sections -->
      <h3 class="font-display text-xl font-bold text-lilac-700 pt-2">Feedback</h3>
      <div class="bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm space-y-4">
       <div>
        <label class="text-sm font-medium text-lilac-700 mb-1 block flex items-center gap-1"><i data-lucide="alert-circle" style="width:14px;height:14px;color:#ef4444"></i> Reclamações</label><textarea id="complaint" rows="2" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300 resize-none" placeholder="Descreva sua reclamação..."></textarea>
       </div>
       <div>
        <label class="text-sm font-medium text-lilac-700 mb-1 block flex items-center gap-1"><i data-lucide="lightbulb" style="width:14px;height:14px;color:#f59e0b"></i> Sugestões</label><textarea id="suggestion" rows="2" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300 resize-none" placeholder="Alguma sugestão de melhoria?"></textarea>
       </div>
       <div>
        <label class="text-sm font-medium text-lilac-700 mb-1 block flex items-center gap-1"><i data-lucide="heart" style="width:14px;height:14px;color:#10b981"></i> Elogios</label><textarea id="praise" rows="2" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300 resize-none" placeholder="O que você mais gostou?"></textarea>
       </div>
      </div><!-- User data -->
      <h3 class="font-display text-xl font-bold text-lilac-700 pt-2">Seus Dados <span class="text-xs font-normal text-lilac-400">(opcional)</span></h3>
      <div class="bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm space-y-3">
       <div>
        <label for="user-name" class="text-xs text-lilac-500 mb-1 block">Nome</label><input id="user-name" type="text" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300" placeholder="Seu nome">
       </div>
       <div>
        <label for="user-email" class="text-xs text-lilac-500 mb-1 block">E-mail</label><input id="user-email" type="email" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300" placeholder="seu@email.com">
       </div>
       <div>
        <label for="user-phone" class="text-xs text-lilac-500 mb-1 block">Telefone</label><input id="user-phone" type="tel" class="w-full border border-lilac-200 rounded-xl p-3 text-sm focus:outline-none focus:ring-2 focus:ring-lilac-300" placeholder="(00) 00000-0000">
       </div>
      </div><!-- Validation message -->
      <div id="validation-msg" class="hidden text-red-500 text-sm bg-red-50 p-3 rounded-xl"></div><!-- Submit --> <button id="submit-btn" type="button" onclick="submitSurvey()" class="w-full bg-lilac-600 hover:bg-lilac-700 text-white py-4 rounded-2xl font-medium transition-all shadow-lg shadow-lilac-200 active:scale-95 flex items-center justify-center gap-2"> <span id="submit-text">Enviar Avaliação</span>
       <div id="submit-spinner" class="hidden w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div></button>
     </form>
    </div>
   </div><!-- Screen: Thank You -->
   <div id="screen-thanks" class="screen flex-col items-center justify-center w-full min-h-full px-6 py-12 text-center" style="background:linear-gradient(160deg,#faf8f5 0%,#f3e8ff 50%,#e9d5ff 100%)">
    <div class="fade-in max-w-md mx-auto">
     <div class="mx-auto mb-6 w-20 h-20 rounded-full bg-lilac-100 flex items-center justify-center">
      <i data-lucide="check-circle" style="width:40px;height:40px;color:#9333ea"></i>
     </div>
     <h2 id="thanks-title" class="font-display text-3xl font-bold text-lilac-700 mb-3">Obrigado!</h2>
     <p id="thanks-msg" class="text-lilac-500 mb-8">Obrigado por avaliar a FlexBag 360!</p><button onclick="resetAndHome()" class="bg-lilac-600 hover:bg-lilac-700 text-white px-8 py-3 rounded-2xl font-medium transition-all shadow-lg shadow-lilac-200 active:scale-95">Voltar ao Início</button>
    </div>
