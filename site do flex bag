    <div class="max-w-lg mx-auto w-full"><button onclick="goTo('home')" class="text-lilac-500 mb-4 flex items-center gap-1 text-sm"><i data-lucide="arrow-left" style="width:16px;height:16px"></i> Voltar</button>
