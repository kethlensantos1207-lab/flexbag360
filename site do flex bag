  <script>
// State
let designRating = 0, overallRating = 0;
const radioQuestions = [
  {n:2, q:"A iluminação interna é útil?", key:"lighting_useful"},
  {n:3, q:"A entrada USB atende suas necessidades?", key:"usb_needs"},
  {n:4, q:"O compartimento térmico funciona bem?", key:"thermal_works"},
  {n:5, q:"Você considera a bolsa segura?", key:"secure_bag"},
  {n:6, q:"A qualidade do material atende suas expectativas?", key:"material_quality"},
  {n:7, q:"A bolsa é prática no dia a dia?", key:"practical_daily"},
  {n:8, q:"O tamanho é adequado?", key:"size_adequate"},
  {n:9, q:"Você recomendaria a FlexBag 360?", key:"would_recommend"}
];
const radioOpts = ["Sim","Parcialmente","Não"];

// Build radio questions
const rqContainer = document.getElementById('radio-questions');
radioQuestions.forEach(rq => {
  const div = document.createElement('div');
  div.className = 'bg-white rounded-2xl p-5 border border-lilac-100 shadow-sm';
  div.innerHTML = `<p class="text-sm font-medium text-lilac-700 mb-3">${rq.n}. ${rq.q}</p>
    <div class="flex gap-4">${radioOpts.map((o,i) => `<label class="flex items-center gap-2 text-sm text-lilac-600 cursor-pointer"><input type="radio" name="${rq.key}" value="${o}"><span>${o}</span></label>`).join('')}</div>`;
  rqContainer.appendChild(div);
});

// Build stars
function buildStars(containerId, setter) {
  const c = document.getElementById(containerId);
  for(let i=1;i<=5;i++){
    const s = document.createElement('button');
    s.type='button'; s.className='star-btn text-lilac-200'; s.dataset.v=i;
    s.innerHTML=`<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
    s.onclick=()=>{ setter(i); updateStars(containerId, i); updateProgress(); };
    c.appendChild(s);
  }
}
function updateStars(containerId, val) {
  document.getElementById(containerId).querySelectorAll('.star-btn').forEach(b => {
    b.className = 'star-btn ' + (parseInt(b.dataset.v)<=val?'text-yellow-400':'text-lilac-200');
  });
}
buildStars('stars-design', v=>designRating=v);
buildStars('stars-overall', v=>overallRating=v);

// Progress
function updateProgress() {
  let answered = 0;
  if(designRating>0) answered++;
  radioQuestions.forEach(rq => { if(document.querySelector(`input[name="${rq.key}"]:checked`)) answered++; });
  if(overallRating>0) answered++;
  document.getElementById('progress-text').textContent = answered+'/10';
  document.getElementById('progress-bar').style.width = (answered*10)+'%';
}
document.querySelectorAll('input[type=radio]').forEach(r=>r.addEventListener('change', updateProgress));

// Navigation
function goTo(screen) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+screen).classList.add('active');
  document.getElementById('app').scrollTop=0;
  lucide.createIcons();
}

function resetAndHome() {
  designRating=0; overallRating=0;
  updateStars('stars-design',0); updateStars('stars-overall',0);
  document.querySelectorAll('input[type=radio]').forEach(r=>r.checked=false);
  document.querySelectorAll('textarea').forEach(t=>t.value='');
  document.querySelectorAll('#survey-form input[type=text],#survey-form input[type=email],#survey-form input[type=tel]').forEach(i=>i.value='');
  updateProgress();
  document.getElementById('validation-msg').classList.add('hidden');
  goTo('home');
}

// Submit
async function submitSurvey() {
  const vm = document.getElementById('validation-msg');
  // Validate required: both star ratings and all radio questions
  if(designRating===0 || overallRating===0) { vm.textContent='Por favor, preencha as avaliações por estrelas.'; vm.classList.remove('hidden'); return; }
  for(const rq of radioQuestions) {
    if(!document.querySelector(`input[name="${rq.key}"]:checked`)) { vm.textContent=`Por favor, responda a pergunta ${rq.n}.`; vm.classList.remove('hidden'); return; }
  }
  vm.classList.add('hidden');

  const btn = document.getElementById('submit-btn');
  const txt = document.getElementById('submit-text');
  const spin = document.getElementById('submit-spinner');
  btn.disabled=true; txt.textContent='Enviando...'; spin.classList.remove('hidden');

  const record = {
    type: 'survey',
    design_rating: designRating,
    overall_rating: overallRating,
    additional_comment: document.getElementById('additional-comment').value||'',
    complaint: document.getElementById('complaint').value||'',
    suggestion: document.getElementById('suggestion').value||'',
    praise: document.getElementById('praise').value||'',
    user_name: document.getElementById('user-name').value||'',
    user_email: document.getElementById('user-email').value||'',
    user_phone: document.getElementById('user-phone').value||'',
    submitted_at: new Date().toISOString()
  };
  radioQuestions.forEach(rq => { record[rq.key] = document.querySelector(`input[name="${rq.key}"]:checked`).value; });

  const result = await window.dataSdk.create(record);
  btn.disabled=false; txt.textContent='Enviar Avaliação'; spin.classList.add('hidden');
  if(result.isOk) { goTo('thanks'); }
  else { vm.textContent='Erro ao enviar. Tente novamente.'; vm.classList.remove('hidden'); }
}

// Data SDK init
let allRecords = [];
window.dataSdk.init({
  onDataChanged(data) { allRecords = data; }
});

// Element SDK
const defaultConfig = {
  background_color: '#f3e8ff',
  surface_color: '#ffffff',
  text_color: '#6b21a8',
  primary_action_color: '#9333ea',
  secondary_action_color: '#c084fc',
  font_family: 'Outfit',
  font_size: 14,
  product_name: 'FlexBag 360',
  slogan: 'Tecnologia, estilo e praticidade em um só lugar',
  thank_you_message: 'Obrigado por avaliar a FlexBag 360!'
};

function applyConfig(config) {
  const c = k => config[k] || defaultConfig[k];
  const font = c('font_family');
  const base = c('font_size');
  document.getElementById('app').style.fontFamily = `${font}, Outfit, sans-serif`;
  document.getElementById('home-title').textContent = c('product_name');
  document.getElementById('home-slogan').textContent = c('slogan');
  document.getElementById('thanks-msg').textContent = c('thank_you_message');

  // Colors
  document.documentElement.style.setProperty('--bg', c('background_color'));
  document.documentElement.style.setProperty('--surface', c('surface_color'));

  // Font sizes
  document.querySelectorAll('.font-display').forEach(el => {
    if(el.classList.contains('text-4xl')) el.style.fontSize = base*2.5+'px';
    else if(el.classList.contains('text-3xl')) el.style.fontSize = base*2+'px';
    else if(el.classList.contains('text-2xl')) el.style.fontSize = base*1.7+'px';
    else if(el.classList.contains('text-xl')) el.style.fontSize = base*1.4+'px';
  });
}

window.elementSdk.init({
  defaultConfig,
  onConfigChange: async (config) => { applyConfig(config); },
  mapToCapabilities: (config) => {
    const c = k => config[k] || defaultConfig[k];
    const make = (key) => ({ get:()=>c(key), set:(v)=>{ config[key]=v; window.elementSdk.setConfig({[key]:v}); } });
    return {
      recolorables: [make('background_color'), make('surface_color'), make('text_color'), make('primary_action_color'), make('secondary_action_color')],
      borderables: [],
      fontEditable: make('font_family'),
      fontSizeable: make('font_size')
    };
  },
  mapToEditPanelValues: (config) => new Map([
    ['product_name', config.product_name || defaultConfig.product_name],
    ['slogan', config.slogan || defaultConfig.slogan],
    ['thank_you_message', config.thank_you_message || defaultConfig.thank_you_message]
  ])
});

